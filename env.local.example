NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-auth-domain"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-storage-bucket"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY="your-recaptcha-enterprise-site-key"
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN="your-debug-token-from-firebase-console"

# Public URL for links inside HTML emails (flow started, interview invite, etc.). No trailing slash.
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Server-only: Firebase Admin SDK (Firestore/Auth bypass rules). Required for
# server actions in src/app/applicant/verification-actions.ts and admin flows.
# Option A — minify the service account JSON to a single line (no line breaks) and paste:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option B — omit this variable and place the downloaded key at either:
#   scripts/service-account.json  or  scripts/service_account.json
# (both gitignored). See SECURITY.md "Local Admin setup".

# Server-only: transactional email via Firestore "Trigger Email" extension (Resend SMTP).
# Server actions write to the `mail` collection; the extension sends. Do not set SMTP here.
#
# VERIFICATION_ADMIN_EMAIL=you@example.com
#   Inbox notified when a user requests identity verification (logical recipient).
#
# EMAIL_USE_REAL_RECIPIENTS=true
#   When unset or not "true", all queued mail is delivered to the pilot inbox hardcoded in
#   src/lib/enqueue-mail.ts (safe for public demos). Set to true on production App Hosting
#   so applicants and the admin receive mail at their real addresses.
#
# RESEND_API_KEY=re_...
#   Still used by the Genkit welcome flow (src/ai/flows/send-welcome-email.ts), not the mail queue.
