# Copy to .env.local and fill in. Never commit secrets.

# Firebase client (public)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# ...

# Server-only: minified JSON for Firebase Admin (see SECURITY.md)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Server-only: AES key for encrypting ATP number and first-class medical date in Firestore.
# Use a long random string; must match across all server instances.
# ENCRYPTION_KEY=

# Optional: verification flow
# VERIFICATION_ADMIN_EMAIL=
