# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.genkit/*
.env*
!.env.example
# Conventional "never sync" bucket (Next.js convention). Covers *.local editor scratch.
*.local

# firebase
firebase-debug.log
firestore-debug.log
.firebase/
scripts/service-account.json
scripts/service_account.json
scripts/*firebase-adminsdk*.json
# Any service account JSON anywhere in the tree (defense-in-depth).
**/*service-account*.json
**/*service_account*.json
**/*firebase-adminsdk*.json

# editor / OS cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
*.pem
*.key
*.p12

# local agent state
.claude/
.cursor/
.aider*

# stray local scratch files (accidental duplicates, touch markers, etc.)
* copy.*
*.bak
*.orig
.modified