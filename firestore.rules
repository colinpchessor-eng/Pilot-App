rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // This rule set assumes that a custom authentication token is created for the user
    // upon successful login, containing their `recordLocator` as a claim.
    match /applicants/{applicantId} {
      // Allow read and write access only to the authenticated user who owns this document.
      // We identify ownership by matching the `recordLocator` in their auth token
      // with the `recordLocator` stored in the document.
      allow read, write: if request.auth != null && request.auth.token.recordLocator == resource.data.recordLocator;
    }
  }
}
