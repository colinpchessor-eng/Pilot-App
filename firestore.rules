rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Privileged fields that only admins (or the Admin SDK) may set ──
    function touchesPrivilegedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['isAdmin', 'role']);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.isAdmin == false
        && (!('role' in request.resource.data) || request.resource.data.role == '');

      allow update: if isOwner(userId)
        && !touchesPrivilegedFields();

      // Admins can read/write any user doc (including isAdmin/role)
      allow read, write: if isAdmin();
    }

    // ── candidateIds ───────────────────────────────────────────────────
    match /candidateIds/{candidateId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, delete: if isAdmin();

      // Regular users: can only claim an unclaimed candidate ID for themselves
      allow update: if isSignedIn()
        && request.resource.data.status == 'claimed'
        && request.resource.data.assignedUid == request.auth.uid
        && resource.data.status != 'claimed';

      // Admins can update any candidate ID (reset, reassign, etc.)
      allow update: if isAdmin();
    }

    // ── legacyData ─────────────────────────────────────────────────────
    match /legacyData/{candidateId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ── pendingVerifications ───────────────────────────────────────────
    match /pendingVerifications/{userId} {
      allow read, create: if isOwner(userId);
      allow update: if isOwner(userId)
        && resource.data.status == 'pending';
      allow read, write: if isAdmin();
    }

    // ── applicants ─────────────────────────────────────────────────────
    match /applicants/{tokenId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();

      // Users can claim their own token
      allow update: if isSignedIn()
        && resource.data.email == request.auth.token.email
        && request.resource.data.assignedUid == request.auth.uid
        && request.resource.data.status == 'claimed';

      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // ── auditLog ───────────────────────────────────────────────────────
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── deletionRequests ───────────────────────────────────────────────
    match /deletionRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── bridge_requests ────────────────────────────────────────────────
    match /bridge_requests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // ── bridge_codes ───────────────────────────────────────────────────
    match /bridge_codes/{codeId} {
      allow get: if isSignedIn();
      allow update: if isSignedIn()
        && request.resource.data.claimedByUid == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // ── mail (for Firebase Trigger Email extension) ────────────────────
    match /mail/{mailId} {
      allow read: if false;
      allow write: if false;
    }

  }
}
