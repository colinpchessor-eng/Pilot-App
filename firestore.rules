rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // A user can read their own profile.
      allow read: if request.auth.uid == userId;

      // A user can create their own profile.
      allow create: if request.auth.uid == userId;

      // A user can update their profile only if it has not been submitted yet.
      // `resource.data` refers to the document's state *before* the update.
      allow update: if request.auth.uid == userId && resource.data.submittedAt == null;

      // Users cannot delete their own profile.
      allow delete: if false;
    }
  }
}
