rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      allow read: if request.auth != null 
        && request.auth.uid == userId;
      allow create: if request.auth != null 
        && request.auth.uid == userId;
      allow update: if request.auth != null 
        && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    match /candidateIds/{candidateId} {
      allow get: if request.auth != null;
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if request.auth != null
        && request.resource.data.status == 'claimed'
        && request.resource.data.assignedUid 
           == request.auth.uid
        && resource.data.status != 'claimed';
    }

    match /legacyData/{candidateId} {
      allow get: if request.auth != null;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /pendingVerifications/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /deletionRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.uid 
           == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

  }
}
