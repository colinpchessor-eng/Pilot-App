{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's application data and profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID from Firebase Auth."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "firstName": {
          "type": [
            "string",
            "null"
          ],
          "description": "The user's first name."
        },
        "lastName": {
          "type": [
            "string",
            "null"
          ],
          "description": "The user's last name."
        },
        "createdAt": {
          "type": "object",
          "description": "The timestamp when the profile was created."
        },
        "firstClassMedicalDate": {
          "type": [
            "object",
            "null"
          ],
          "description": "Date of the user's first class medical certificate."
        },
        "atpNumber": {
          "type": [
            "string",
            "null"
          ],
          "description": "The user's ATP certificate number."
        },
        "flightTime": {
          "type": "object",
          "properties": {
            "total": {
              "type": "number"
            },
            "turbinePic": {
              "type": "number"
            },
            "military": {
              "type": "number"
            },
            "civilian": {
              "type": "number"
            },
            "multiEngine": {
              "type": "number"
            },
            "instructor": {
              "type": "number"
            },
            "evaluator": {
              "type": "number"
            },
            "sic": {
              "type": "number"
            },
            "other": {
              "type": "number"
            }
          }
        },
        "typeRatings": {
          "type": "string",
          "description": "A list of the user's aircraft type ratings and certificates, separated by newlines or commas."
        },
        "employmentHistory": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/EmploymentHistory"
          }
        },
        "safetyQuestions": {
          "type": "object",
          "properties": {
            "terminations": { "$ref": "#/backend/entities/SafetyQuestion" },
            "askedToResign": { "$ref": "#/backend/entities/SafetyQuestion" },
            "accidents": { "$ref": "#/backend/entities/SafetyQuestion" },
            "incidents": { "$ref": "#/backend/entities/SafetyQuestion" },
            "flightViolations": { "$ref": "#/backend/entities/SafetyQuestion" },
            "certificateAction": { "$ref": "#/backend/entities/SafetyQuestion" },
            "pendingFaaAction": { "$ref": "#/backend/entities/SafetyQuestion" },
            "failedCheckRide": { "$ref": "#/backend/entities/SafetyQuestion" },
            "formalDiscipline": { "$ref": "#/backend/entities/SafetyQuestion" },
            "investigationBoard": { "$ref": "#/backend/entities/SafetyQuestion" },
            "previousInterview": { "$ref": "#/backend/entities/SafetyQuestion" },
            "trainingCommitmentConflict": { "$ref": "#/backend/entities/SafetyQuestion" },
            "otherInfo": { "$ref": "#/backend/entities/SafetyQuestion" }
          }
        },
        "submittedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "isCertified": {
          "type": "boolean",
          "description": "Whether the user has certified their application."
        },
        "printedName": {
          "type": [
            "string",
            "null"
          ],
          "description": "The user's printed name for certification."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the user has administrator privileges."
        }
      },
      "required": [
        "uid",
        "email",
        "createdAt"
      ]
    },
    "EmploymentHistory": {
      "title": "Employment History",
      "description": "Represents a single entry in a user's employment history.",
      "type": "object",
      "properties": {
        "employerName": {
          "type": "string"
        },
        "jobTitle": {
          "type": "string"
        },
        "startDate": {
          "type": "object"
        },
        "endDate": {
          "type": [
            "object",
            "null"
          ]
        },
        "aircraftTypes": {
          "type": "string"
        },
        "totalHours": {
          "type": "number"
        },
        "duties": {
          "type": "string"
        }
      },
      "required": [
        "employerName",
        "jobTitle",
        "startDate",
        "aircraftTypes",
        "totalHours",
        "duties"
      ]
    },
    "SafetyQuestion": {
      "title": "Safety Question",
      "description": "Represents a single safety question with an answer and an optional explanation.",
      "type": "object",
      "properties": {
        "answer": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "yes",
            "no"
          ]
        },
        "explanation": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "auth": {
    "providers": [
      "email-password",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/UserProfile"
      },
      "description": "Stores user profile and application data, keyed by user's auth UID."
    }
  }
}
