{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's application data and profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID from Firebase Auth."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "firstName": {
          "type": [
            "string",
            "null"
          ],
          "description": "The user's first name."
        },
        "lastName": {
          "type": [
            "string",
            "null"
          ],
          "description": "The user's last name."
        },
        "createdAt": {
          "type": "object",
          "description": "The timestamp when the profile was created."
        },
        "flightTime": {
          "type": "object",
          "properties": {
            "total": {
              "type": "number"
            },
            "turbinePic": {
              "type": "number"
            },
            "military": {
              "type": "number"
            },
            "civilian": {
              "type": "number"
            },
            "multiEngine": {
              "type": "number"
            },
            "instructor": {
              "type": "number"
            },
            "evaluator": {
              "type": "number"
            },
            "sic": {
              "type": "number"
            },
            "other": {
              "type": "number"
            }
          }
        },
        "typeRatings": {
          "type": "array"
        },
        "employmentHistory": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/EmploymentHistory"
          }
        },
        "safetyQuestions": {
          "type": "object",
          "properties": {
            "terminations": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "askedToResign": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "accidents": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "incidents": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "flightViolations": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "certificateAction": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "pendingFaaAction": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "failedCheckRide": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "formalDiscipline": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "investigationBoard": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "previousInterview": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "trainingCommitmentConflict": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            },
            "otherInfo": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "yes",
                "no"
              ]
            }
          }
        },
        "safetyExplanation": {
          "type": [
            "string",
            "null"
          ],
          "description": "Explanation for any 'yes' answers in the safety questionnaire."
        },
        "resumeFileName": {
          "type": [
            "string",
            "null"
          ]
        },
        "submittedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "isCertified": {
          "type": "boolean",
          "description": "Whether the user has certified their application."
        },
        "printedName": {
          "type": [
            "string",
            "null"
          ],
          "description": "The user's printed name for certification."
        }
      },
      "required": [
        "uid",
        "email",
        "createdAt"
      ]
    },
    "EmploymentHistory": {
      "title": "Employment History",
      "description": "Represents a single entry in a user's employment history.",
      "type": "object",
      "properties": {
        "employerName": {
          "type": "string"
        },
        "jobTitle": {
          "type": "string"
        },
        "startDate": {
          "type": "object"
        },
        "endDate": {
          "type": [
            "object",
            "null"
          ]
        },
        "aircraftTypes": {
          "type": "string"
        },
        "totalHours": {
          "type": "number"
        },
        "duties": {
          "type": "string"
        }
      },
      "required": [
        "employerName",
        "jobTitle",
        "startDate",
        "aircraftTypes",
        "totalHours",
        "duties"
      ]
    }
  },
  "auth": {
    "providers": [
      "email-password",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/UserProfile"
      },
      "description": "Stores user profile and application data, keyed by user's auth UID."
    }
  }
}
